# Telegram Bot для уведомлений о заявках
# 1. Напишите @BotFather в Telegram, создайте бота и получите токен
# 2. Напишите боту любое сообщение, затем откройте:
#    https://api.telegram.org/bot<ТОКЕН>/getUpdates
#    Найдите chat.id — это ваш CHAT_ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Admin Password
ADMIN_PASSWORD=admin123

# CSRF Secret for form protection
CSRF_SECRET=your-secret-key-change-in-production

# Yandex Metrika (опционально)
NEXT_PUBLIC_YANDEX_METRICA_ID=
